# Banco de dados — Caminho para o arquivo SQLite (relativo à raiz do projeto)
DATABASE_URL="file:./prisma/data.sqlite"

# Segredo usado para assinar e verificar os tokens JWT.
# NUNCA commite o valor real. Gere uma string longa e aleatória.
# Exemplo: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque_por_uma_chave_secreta_forte_e_aleatoria"

# Porta em que o servidor Express irá escutar (padrão: 3000)
PORT=3000
